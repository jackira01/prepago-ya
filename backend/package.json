{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "bun build ./src/server.ts --outdir ./dist --target bun",
    "build:prod": "rm -rf dist && bun build ./src/server.ts --outdir ./dist --target bun",
    "start": "bun dist/server.js",
    "start:prod": "NODE_ENV=production bun dist/server.js",
    "dev": "bun --watch src/server.ts",
    "migrate:config-parameters": "bun scripts/migrate-config-parameters.ts",
    "seed:plans": "FEATURE_VISIBILITY_ENGINE=true bun src/modules/plans/plans.seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.19.0",
    "mongoose": "^8.16.1",
    "mongoose-paginate-v2": "^1.9.1",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "node-mailjet": "^6.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.8.3"
  }
}