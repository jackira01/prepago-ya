{
  "name": "prepago-ya",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "bun run --filter backend build:prod",
    "build:frontend": "bun run --filter frontend build",
    "start": "bun run start:backend",
    "start:backend": "bun run --filter backend start:prod",
    "start:frontend": "bun run --filter frontend start",
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "bun run --filter backend dev",
    "dev:frontend": "bun run --filter frontend dev",
    "install:all": "bun install",
    "clean": "bun run --filter backend clean && rm -rf frontend/.next",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "concurrently": "^9.1.0"
  },
  "packageManager": "bun@1.2.0"
}